# Drone Image Semantic Search Engine backend

# Server
ENVIRONMENT=development
HOST=127.0.0.1
PORT=8000
RELOAD=true
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LOG_LEVEL=info

# Upload safety
MAX_UPLOAD_SIZE_MB=25
MAX_BATCH_FILES=25
MAX_IMAGE_PIXELS=50000000
SEARCH_SCORE_THRESHOLD=0.18

# Qdrant vector database
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=your_qdrant_api_key

# Report generation (Groq)
GROQ_API_KEY=your_groq_api_key_here
GROQ_REPORT_MODEL=llama-3.3-70b-versatile

# Cloudinary image storage (optional)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=drone-search

# Model loading
USE_GPU=false
BLIP_MODEL_NAME=Salesforce/blip-image-captioning-base
YOLO_MODEL_NAME=yolov8s.pt
CLIP_MODEL_NAME=ViT-L-14
CLIP_PRETRAINED=laion2b_s32b_b82k
# Only set true if you trust the YOLO checkpoint and need legacy PyTorch loading.
ALLOW_UNSAFE_YOLO_LOAD=false
